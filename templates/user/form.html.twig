{% extends 'base.html.twig' %}

{% block title %}Gestion des comptes utilisateur{% endblock %}

{% block body %}

    <div class="container mt-4">
    <h1>{{ editMode ? 'Modifier un utilisateur' : 'Ajouter un utilisateur' }}</h1>

    {{ form_start(form) }}

<div class="row">
    <div class="col-md-6">
        {{ form_row(form.firstname) }}
    </div>
    <div class="col-md-6">
        {{ form_row(form.lastname) }}
    </div>
</div>

{{ form_row(form.email) }}
{{ form_row(form.password) }}
{{ form_row(form.hired_date) }}
{{ form_row(form.contract_end_date) }}
{{ form_row(form.status) }}
{{ form_row(form.photo) }}
{{ form_row(form.color) }}
{{ form_row(form.role) }}

<div class="mt-3 d-flex justify-content-between">
    <a href="{{ path('user_list') }}" class="btn btn-secondary">Retour à la liste</a>
    <button class="btn btn-primary">
        {{ editMode ? 'Enregistrer les modifications' : 'Créer' }}
    </button>
</div>

{{ form_end(form) }}

    {% if editMode %}
        <hr>
        <form method="post"
              action="{{ path('user_list', {'id': form.vars.value.id}) }}"
              onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette utilisateur ?');">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ form.vars.value.id) }}">
            <button class="btn btn-rouge">Supprimer</button>
        </form>
    {% endif %}
</div>

{% endblock %}