{% extends 'base.html.twig' %}

{% block title %}Gestion des comptes utilisateur{% endblock %}

{% block body %}
{# 1. Préparer la liste des utilisateurs #}
{% set userItems = [] %}
{% for u in allUsers %}
    {% set userItems = userItems|merge([{ id: u.id, label: u.lastname|upper ~ ' ' ~ u.firstname }]) %}
{% endfor %}

{# 2. Préparer la liste des statuts #}
{% set statusItems = [
    { id: '1', label: 'Actif' },
    { id: '0', label: 'Inactif' }
] %}
    <h1 class="">Gestion des comptes utilisateur</h1>

    {{ include('composants/button.html.twig', {type: 'confirmer', label: '+ Ajouter un utilisateur',href: path('user_add'),}) }}    

    <div class="card bg-light mb-4">
    <div class="card-body">
        <form method="get" action="{{ path('user_list') }}" class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">
            
            {# Recherche textuelle #}
            {{ include('composants/input_text.html.twig', {
                'label': 'Recherche',
                'placeholder': 'Nom, prénom, email...',
                'value': filters.search,
                'name': 'search'
            }) }}

            {# Sélecteur par Utilisateur #}
            {{ include('composants/select_multi.html.twig', {
                label: 'Développeur',
                name: 'user_id',
                placeholder: 'Sélectionner un développeur',
                items: userItems,
                multiple: false
            }) }}

            {# Sélecteur Statut #}
            {{ include('composants/select_multi.html.twig', {
                label: 'Statut',
                name: 'status',
                placeholder: 'Tous les statuts',
                items: statusItems,
                multiple: false
            }) }}

            {# Boutons #}
            <div class="flex gap-2">
                {{ include('composants/button.html.twig', {type: 'filtrer', label: 'Filtrer'}) }}
                {{ include('composants/button.html.twig', {
                    type: 'annuler', 
                    label: 'Réinitialiser',
                    href: path('user_list'),
                }) }}
                
            </div>

        </form>
    </div>
</div>
    <div class ="">
    <table class="table table-striped table-bordered">
            <thead class="table-dark">
                <tr>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Dernière connexion</th>
                    <th>Statut</th>
                    <th>Rôle</th>
                    <th>Date d'embauche</th>
                    <th>Date fin contrat</th>
                    <th>Couleur</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>                        
                        <td>{{ user.lastname }}</td>
                        <td>{{ user.firstname }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.lastLogin ? user.lastLogin|date('d/m/Y H:i') : 'Jamais' }}</td>
                        <td>{{ user.status ? 'Actif' : 'Inactif' }}</td>
                        <td>{{ user.role.label ?? 'Aucun' }}</td>
                        <td>{{ user.hiredDate ? user.hiredDate|date('d/m/Y') : '' }}</td>
                        <td>{{ user.contractEndDate ? user.contractEndDate|date('d/m/Y') : 'non définis' }}</td>
                        <td style= "color :{{ user.color }} ">{{ user.color }}</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a href="{{ path('user_edit', {'id': user.id}) }}" class="btn btn-sm btn-outline-primary">
                                    Modifier
                                </a>
                                <form method="post" 
                                    action="{{ path('user_delete', {'id': user.id}) }}" 
                                    onsubmit="return confirm('Êtes-vous sûr de vouloir archiver cet utilisateur ?');"
                                    style="display:inline;">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                    
                                    <button class="btn btn-sm btn-outline-danger">
                                        Supprimer
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" class="">Aucun utilisateur trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>


{% endblock %}