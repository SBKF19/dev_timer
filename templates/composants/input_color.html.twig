{# templates/composants/input_color.html.twig #}
<div class="w-full" x-data="{ color: '{{ value|default('#4f46e5') }}' }">
    <label class="block text-[15px] font-normal text-gray-500 mb-1">
        {{ label|default('Couleur associée') }}
    </label>
    
    <div class="flex items-center gap-3 p-2 border border-black rounded-xl bg-white h-[3.5rem]">
        {# Le cercle cliquable qui déclenche le sélecteur #}
        <div class="relative w-10 h-10 shrink-0 overflow-hidden rounded-lg border border-gray-200">
            <input type="color" 
                   name="{{ name }}" 
                   id="{{ id|default(name) }}"
                   x-model="color"
                   class="absolute -inset-2 w-[200%] h-[200%] cursor-pointer border-none bg-transparent">
        </div>

        {# Affichage du code Hexa #}
        <div class="flex-1 px-2">
            <span class="text-sm font-mono font-medium text-gray-700 uppercase" x-text="color"></span>
        </div>

        {# Icône décorative #}
        <div class="pr-2 text-gray-400">
            <i class="fas fa-palette"></i>
        </div>
    </div>
</div>