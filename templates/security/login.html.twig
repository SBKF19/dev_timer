{% extends 'base.html.twig' %}

{% block title %}Log in!
{% endblock %}

{% block body %}
	{# On force le texte en noir sur tout le conteneur avec text-black #}
	<div class="flex flex-col items-center justify-center min-h-screen gap-4 text-black">
		<form method="post" class="w-full max-w-sm p-6 bg-white rounded-lg shadow-md">
			{% if error %}
				<div class="p-3 mb-4 text-sm text-red-700 bg-red-100 rounded-lg">
					{{ error.messageKey|trans(error.messageData, 'security') }}
				</div>
			{% endif %}

			{% if app.user %}
				<div class="mb-3">
					Vous êtes connecté en tant que
					{{ app.user.userIdentifier }},
					<a href="{{ logout_path() }}" class="text-blue-600 underline">Déconnexion</a>
				</div>
			{% endif %}

			<h1 class="mb-6 text-2xl font-bold text-center">Connexion</h1>

			<div class="mb-4">
				<label for="inputEmail" class="block mb-1 font-medium">Email</label>
				<input type="email" value="{{ last_username }}" name="email" id="inputEmail" class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="email" required autofocus>
			</div>

			<div class="mb-6">
				<div class="flex justify-between mb-1">
					<label for="inputPassword" class="font-medium">Mot de passe</label>
					{# Lien mot de passe oublié #}
					<a href="{{ path('app_forgot_password_request') }}" class="text-sm text-blue-600 hover:underline">
						Mot de passe oublié ?
					</a>
				</div>
				<input type="password" name="password" id="inputPassword" class="w-full px-3 py-2 border border-gray-300 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" autocomplete="current-password" required>
			</div>

			<input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

			<button class="w-full py-3 text-white transition bg-blue-600 rounded-lg hover:bg-blue-700" type="submit">
				Accéder au portail
			</button>
		</form>
	</div>
{% endblock %}
